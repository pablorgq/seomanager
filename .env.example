# Local development port (Railway sets PORT automatically)
PORT=3000

# OpenAI API key — used server-side to proxy requests to OpenAI
# On Railway: set this in the Variables tab of your service dashboard
# Never commit your real key — the actual .env file is gitignored
OPENAI_API_KEY=sk-...

# Login credentials — override these in Railway Variables
AUTH_USER=pablo
AUTH_PASS=your-password-here
