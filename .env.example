# Local development port (Railway sets PORT automatically)
PORT=3000

# OpenAI API key — used server-side to proxy requests to OpenAI
# On Railway: set this in the Variables tab of your service dashboard
# Never commit your real key — the actual .env file is gitignored
OPENAI_API_KEY=sk-...

# Login credentials — REQUIRED in production (server exits if AUTH_PASS is missing)
# Set both in Railway Variables tab; never commit real values
AUTH_USER=pablo
AUTH_PASS=your-password-here

# Google Cloud Storage (optional) — enables "Create GCS Folder" per blog brand
# GCS_BUCKET_NAME: an existing bucket with fine-grained (non-uniform) access control enabled
# GCS_SERVICE_ACCOUNT_JSON: the full service account key JSON, as a single-line string,
#   with Storage Object Admin role on the bucket
GCS_BUCKET_NAME=your-bucket-name
GCS_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...", ...}
